# =============================================================================
# Bilvantis Training Intelligence Platform — Environment Template
# =============================================================================
# Copy to backend/.env and fill in values marked REQUIRED.
# deploy.sh creates this file automatically from the values below.
# NEVER commit backend/.env to version control.
# =============================================================================

# ── Database ── SQLite, no server needed ─────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./feedback_platform.db
SYNC_DATABASE_URL=sqlite:///./feedback_platform.db

# ── Queue ── In-memory Celery, no Redis needed ───────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# ── Security ── REQUIRED ─────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FEEDBACK_TOKEN_EXPIRE_HOURS=72

# ── AI ── REQUIRED for analytics chat ────────────────────────────────────────
# Get key at: https://console.groq.com/keys  (free tier available)
# Model used: llama-3.3-70b-versatile (chat), llama-3.1-8b-instant (health)
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY
GEMINI_API_KEY=

# ── Email ── Gmail SMTP (optional) ───────────────────────────────────────────
# Use a Gmail App Password — NOT your account password.
# Enable at: https://myaccount.google.com/apppasswords
# Leave blank to disable email; feedback links still work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
SMTP_FROM_EMAIL=your.email@gmail.com
SMTP_FROM_NAME=Bilvantis TIP

# ── Email ── SendGrid alternative (optional) ─────────────────────────────────
# Only used if SMTP_USER is blank.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@bilvantis.io

# ── Application URLs ── auto-set by deploy.sh ─────────────────────────────────
# deploy.sh replaces VM_IP with the actual VM IP address at deploy time.
FRONTEND_URL=http://VM_IP:3003
BACKEND_URL=http://VM_IP:8002

# ── App Settings ─────────────────────────────────────────────────────────────
FEEDBACK_THRESHOLD=5
PGVECTOR_DIMENSION=768
APP_NAME=Bilvantis Training Intelligence Platform
APP_VERSION=1.0.0
DEBUG=False
