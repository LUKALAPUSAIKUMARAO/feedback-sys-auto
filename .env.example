# =============================================================================
# Bilvantis Training Intelligence Platform — Environment Variables
# =============================================================================
# Copy this file to backend/.env and fill in all required values.
# NEVER commit backend/.env to version control (it is in .gitignore).
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite — no server required. Path is relative to the backend/ working dir.
DATABASE_URL=sqlite+aiosqlite:///./feedback_platform.db
SYNC_DATABASE_URL=sqlite:///./feedback_platform.db

# ── Cache / Task Queue ────────────────────────────────────────────────────────
# Using in-memory fake-redis — no Redis server required.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS

# Token lifetimes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FEEDBACK_TOKEN_EXPIRE_HOURS=72

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# REQUIRED — Get your key from https://console.groq.com/keys
# Model used: llama-3.3-70b-versatile (analytics chat), llama-3.1-8b-instant (health ping)
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY

# Optional — Gemini for embeddings (leave blank to skip)
GEMINI_API_KEY=

# ── Email — Gmail SMTP (recommended) ─────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Enable at: myaccount.google.com/apppasswords
# Leave blank to disable email (feedback links still work, just not emailed).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=your.email@gmail.com
SMTP_FROM_NAME=Bilvantis TIP

# ── Email — SendGrid (alternative) ───────────────────────────────────────────
# Only used if SMTP_USER is blank. Leave both blank to disable email.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Application URLs ──────────────────────────────────────────────────────────
# Set to the VM's public/private IP or domain name.
# These are auto-updated by deploy.sh based on detected IP.
FRONTEND_URL=http://YOUR_VM_IP:3003
BACKEND_URL=http://YOUR_VM_IP:8002

# ── App Settings ──────────────────────────────────────────────────────────────
# Minimum feedback submissions before analytics are generated
FEEDBACK_THRESHOLD=5

# Embedding vector dimension (must match model — 768 for Gemini)
PGVECTOR_DIMENSION=768

APP_NAME=Bilvantis Training Intelligence Platform
APP_VERSION=1.0.0

# Set to True only for local development (enables debug logs, auto-reload)
DEBUG=False
